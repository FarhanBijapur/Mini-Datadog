  "info": {
    "description": "Local observability demo API for ingesting logs, reading recent persisted events, and exposing real-time metrics for the React dashboard.",
    "title": "Mini Datadog",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/healthz": {
      "get": {
        "description": "Returns a lightweight health signal for local readiness checks.",
        "operationId": "health_check_healthz_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "status": "ok"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "API is healthy."
          }
        },
        "summary": "Check API health",
        "tags": [
          "health"
        ]
      }
    },
    "/logs": {
      "get": {
        "description": "Returns the most recently processed logs from MongoDB. The response is ordered by processing time descending and wrapped in a `logs` array.",
        "operationId": "recent_logs_logs_get",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 50,
              "maximum": 200,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "logs": [
                    {
                      "attributes": {
                        "latency_ms": 420,
                        "region": "ap-south-1"
                      },
                      "level": "ERROR",
                      "message": "payment authorization failed",
                      "processed_at": "2026-07-10T12:00:02+00:00",
                      "received_at": "2026-07-10T12:00:01+00:00",
                      "service": "checkout-api",
                      "source": "demo-generator",
                      "span_id": "span-456",
                      "tags": [
                        "demo",
                        "local"
                      ],
                      "timestamp": "2026-07-10T12:00:00+00:00",
                      "trace_id": "trace-123"
                    }
                  ]
                },
                "schema": {
                  "$ref": "#/components/schemas/RecentLogsResponse"
                }
              }
            },
            "description": "Recent logs returned successfully."
          },
          "422": {
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "ctx": {
                        "ge": 1
                      },
                      "input": "0",
                      "loc": [
                        "query",
                        "limit"
                      ],
                      "msg": "Input should be greater than or equal to 1",
                      "type": "greater_than_equal"
                    }
                  ]
                }
              }
            },
            "description": "The `limit` query parameter failed validation."
          }
        },
        "summary": "Read recent logs",
        "tags": [
          "logs"
        ]
      },
      "post": {
        "description": "Validates a log event and enqueues it for asynchronous processing. A `202 Accepted` response means the event was accepted into the in-memory ingestion queue, not necessarily persisted yet.",
        "operationId": "ingest_log_logs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogIn",
                "examples": [
                  {
                    "attributes": {
                      "latency_ms": 420,
                      "region": "ap-south-1"
                    },
                    "level": "ERROR",
                    "message": "payment authorization failed",
                    "service": "checkout-api",
                    "source": "demo-generator",
                    "span_id": "span-456",
                    "tags": [
                      "demo",
                      "local"
                    ],
                    "timestamp": "2026-07-10T12:00:00+00:00",
                    "trace_id": "trace-123"
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "example": {
                  "queue_depth": 1,
                  "status": "accepted"
                },
                "schema": {
                  "$ref": "#/components/schemas/LogAcceptedResponse"
                }
              }
            },
            "description": "Log event accepted into the ingestion queue."
          },
          "422": {
            "content": {
              "application/json": {
                "example": {
                  "detail": [
                    {
                      "input": {
                        "level": "ERROR",
                        "message": "payment authorization failed"
                      },
                      "loc": [
                        "body",
                        "service"
                      ],
                      "msg": "Field required",
                      "type": "missing"
                    }
                  ]
                }
              }
            },
            "description": "The request body failed FastAPI/Pydantic validation."
          },
          "429": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "Ingestion queue is full. Retry later."
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "The ingestion queue is full and the client should retry later."
          }
        },
        "summary": "Ingest a log event",
        "tags": [
          "logs"
        ]
      }
    },
    "/metrics": {
      "get": {
        "description": "Returns a real-time observability snapshot assembled from in-memory counters, rolling error windows, service-level frequency tracking, and the current anomaly detection state.",
        "operationId": "get_metrics_metrics_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "anomaly_detection": {
                    "anomaly_active": true,
                    "last_anomaly": {
                      "affected_service": "checkout-api",
                      "current_count": 8,
                      "previous_count": 3,
                      "timestamp": "2026-07-10T12:00:30+00:00"
                    }
                  },
                  "error_analytics": {
                    "current_window_error_count": 8,
                    "previous_window_error_count": 3,
                    "total_error_count": 14
                  },
                  "frequency_tracking": {
                    "frequency_by_service_level": {
                      "checkout-api:ERROR": 9,
                      "checkout-api:INFO": 39
                    }
                  },
                  "service_level_insights": {
                    "error_count_per_service": {
                      "checkout-api": 9,
                      "payment-worker": 5
                    },
                    "logs_per_service": {
                      "checkout-api": 48,
                      "payment-worker": 31
                    }
                  },
                  "system_throughput": {
                    "db_failures_total": 0,
                    "duplicate_logs_total": 2,
                    "queue_depth": 3,
                    "queue_rejections_total": 0,
                    "total_logs_failed": 1,
                    "total_logs_processed": 118,
                    "total_logs_received": 120,
                    "worker_restarts_total": 0,
                    "worker_status": "running"
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/MetricsResponse"
                }
              }
            },
            "description": "Metrics snapshot returned successfully."
          }
        },
        "summary": "Read observability metrics",
        "tags": [
          "metrics"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Readiness and liveness endpoints.",
      "name": "health"
    },
    {
      "description": "Log ingestion and recent-log retrieval endpoints.",
      "name": "logs"
    },
    {
      "description": "Real-time metrics and anomaly detection endpoints.",
      "name": "metrics"
    }
  ]
}
